# .dockerignore for the commit-image build.
# Goal: bake in the FULL repo (including .git history — the grader uses it),
# dropping only local build artifacts and editor/OS cruft. Dev image, not minimal.
#
# NOTE: pjproject keeps real source under per-module build/ directories (e.g.
# pjlib/build/Makefile), so we must NOT exclude `build/`. We only drop compiled
# object/archive/shared outputs and the configure-generated build.mak/user.mak,
# all of which mayhem/build.sh regenerates inside the container.

# ── Compiled outputs (regenerated by build.sh in the container) ───────────────
*.o
*.a
*.so
*.so.*
*.dylib
*.lo
*.la
mayhem-build/
mayhem-tests/
pjlib/bin/
pjlib-util/bin/
pjnath/bin/
pjmedia/bin/
pjsip/bin/
pjsip-apps/bin/
**/output/

# ── configure-generated (regenerated by ./configure) ──────────────────────────
/build.mak
/user.mak
config.log
config.status
**/.depend

# ── Editor / OS noise ─────────────────────────────────────────────────────────
.DS_Store
*.swp
*~
